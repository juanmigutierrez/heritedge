# Copy to .env (never commit .env). Owner: P6 manages vault.
PORT=3001
NODE_ENV=development

# Pick one LLM provider (P1 decides):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Whisper fallback for /transcribe (P2):
OPENAI_API_KEY_WHISPER=

# Chroma (P1) — local container or hosted:
CHROMA_URL=http://localhost:8000

# CORS origin for the web app (P6):
WEB_ORIGIN=http://localhost:5173
