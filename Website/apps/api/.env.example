# Copy to .env (never commit .env). Owner: P6 manages vault.






# Chroma vector database (P1) — local container or hosted:
# Required for RAG. Start Chroma with:
#   docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000

# CORS origin for the web app (P6):
WEB_ORIGIN=http://localhost:5173

# Embedding model API key (P1) — for ingesting knowledge base into Chroma.
# Can reuse OPENAI_API_KEY or GITHUB_TOKEN if available.
# Used by: npm run ingest-kb
# Never put a real key in this example file — only in your local .env
VITE_OPENAI_API_KEY=your-openai-api-key-here